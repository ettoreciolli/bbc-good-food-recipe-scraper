{
  "name": "scraper",
  "version": "0.0.1",
  "description": "BBC Good Food Recipe Scraper",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.frontend.json",
    "build:backend": "tsc -p tsconfig.json",
    "build:frontend": "tsc -p tsconfig.frontend.json",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.frontend.json --noEmit",
    "start": "npm run build && node dist/index.js",
    "dev": "tsc -p tsconfig.frontend.json && tsx watch index.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "Pull",
    "recipe",
    "ingredients",
    "and",
    "methods",
    "from",
    "BBC",
    "Good",
    "Food"
  ],
  "author": "Forbes Gray <fnbg75@gmail.com>",
  "license": "ISC",
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "cheerio": "^0.20.0",
    "express": "^4.13.4",
    "iso8601-duration": "^1.3.0",
    "pluralize": "^8.0.0",
    "request": "^2.69.0"
  },
  "devDependencies": {
    "@types/angular": "^1.8.9",
    "@types/cheerio": "^0.22.35",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/pluralize": "^0.0.33",
    "@types/request": "^2.48.12",
    "tsx": "^4.22.4",
    "typescript": "^5.4.3"
  }
}
